# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/apps/web/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

.env

# testing
/coverage

# next.js
.next/
/apps/web/.next/
/apps/web/out/

# production
/build
/dist
/apps/web/dist

# vendor
vendor/

# misc
.DS_Store
*.pem
.codex/*
!.codex/skills/
!.codex/skills/**
.codex/skills/.system/
.codex/skills/.system/**
.specify/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
!.env.example
/apps/api/.env
/apps/web/.env.local
/apps/web/.env.development.local
/apps/web/.env.test.local
/apps/web/.env.production.local

# vercel
/.vercel

# typescript
*.tsbuildinfo
apps/web/next-env.d.ts

# python
*.pyc
__pycache__/
/apps/api/.venv/
/apps/api/db.sqlite3
/apps/api/staticfiles/
/data/data_movement/
/data/l3_spider/daily_anomaly/
/data/postgres/

*/logs/
apps/api/logs/rag_errors.log

# local dev data (mock parquet files — generated by make_dashboard_mock.py)
/data/pm_spider/

# editor / tool artifacts
.claude/
apps/web/test-results/

# Windows Zone.Identifier sidecar files
*:Zone.Identifier

# system packages
*.deb
