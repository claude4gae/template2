{
  "name": "template2-monorepo",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "agent:audit": "npm run agent:audit:web-boundary && npm run agent:audit:ui && npm run agent:audit:docs",
    "agent:audit:docs": "scripts/agent/check_docs_inventory.sh",
    "agent:audit:ui": "scripts/agent/check_ui_consistency.sh",
    "agent:audit:web-boundary": "scripts/agent/check_frontend_boundaries.sh",
    "web:dev": "npm run dev --workspace web",
    "web:build": "npm run build --workspace web",
    "web:start": "npm run start --workspace web",
    "web:lint": "npm run lint --workspace web"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
